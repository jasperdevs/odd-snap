<Window x:Class="Yoink.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink"
        Height="580" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ThemeMode="System">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="-1" CornerRadius="8"
                      UseAeroCaptionButtons="True"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TabPill" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="12,5" CornerRadius="6" Cursor="Hand"
                                Background="Transparent" WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="12"
                                       Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                       Opacity="0.4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0CFFFFFF"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Background" Value="#0AFFFFFF"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab bar in title area -->
        <Border Grid.Row="0" Padding="16,8,16,4">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="SettingsTab" Content="Settings" GroupName="Tabs"
                             IsChecked="True" Click="TabChanged" Style="{StaticResource TabPill}"/>
                <RadioButton x:Name="HistoryTab" Content="Screenshots" GroupName="Tabs"
                             Click="TabChanged" Margin="2,0,0,0" Style="{StaticResource TabPill}"/>
                <RadioButton x:Name="OcrTab" Content="Text" GroupName="Tabs"
                             Click="TabChanged" Margin="2,0,0,0" Style="{StaticResource TabPill}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">

            <!-- Settings -->
            <ScrollViewer x:Name="SettingsPanel" VerticalScrollBarVisibility="Auto" Padding="18,6,18,18">
                <StackPanel>
                    <TextBlock Text="Capture" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Screenshot hotkey" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox x:Name="HotkeyBox" Grid.Column="1" IsReadOnly="True"
                                     FontSize="12" Padding="10,5" MinWidth="115" TextAlignment="Center"
                                     WindowChrome.IsHitTestVisibleInChrome="True"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                     GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="OCR hotkey" FontSize="13"/>
                                <TextBlock Text="Extract text from screen" FontSize="11" Opacity="0.3"/>
                            </StackPanel>
                            <TextBox x:Name="OcrHotkeyBox" Grid.Column="1" IsReadOnly="True"
                                     FontSize="12" Padding="10,5" MinWidth="115" TextAlignment="Center"
                                     WindowChrome.IsHitTestVisibleInChrome="True"
                                     PreviewKeyDown="OcrHotkeyBox_PreviewKeyDown"
                                     GotFocus="OcrHotkeyBox_GotFocus" LostFocus="OcrHotkeyBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="After capture" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AfterCaptureCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                      WindowChrome.IsHitTestVisibleInChrome="True"
                                      SelectionChanged="AfterCaptureCombo_SelectionChanged">
                                <ComboBoxItem Content="Copy to clipboard"/>
                                <ComboBoxItem Content="Show preview"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <TextBlock Text="Saving" Style="{StaticResource SectionLabel}" Margin="0,14,0,6"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="SaveToFileCheck" Content="Save screenshots to file" FontSize="13"
                                      WindowChrome.IsHitTestVisibleInChrome="True"
                                      Checked="SaveToFileCheck_Changed" Unchecked="SaveToFileCheck_Changed"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" x:Name="SaveDirPanel" Visibility="Collapsed">
                                <TextBox x:Name="SaveDirBox" IsReadOnly="True" FontSize="11" Padding="7,4" Width="280"
                                         WindowChrome.IsHitTestVisibleInChrome="True"/>
                                <Button Content="Browse" FontSize="11" Padding="8,4" Margin="5,0,0,0"
                                        WindowChrome.IsHitTestVisibleInChrome="True" Click="BrowseButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <CheckBox x:Name="SaveHistoryCheck" Content="Save capture history" FontSize="13"
                                  WindowChrome.IsHitTestVisibleInChrome="True"
                                  Checked="SaveHistoryCheck_Changed" Unchecked="SaveHistoryCheck_Changed"/>
                    </Border>

                    <TextBlock Text="General" Style="{StaticResource SectionLabel}" Margin="0,14,0,6"/>

                    <Border Style="{StaticResource Card}">
                        <CheckBox x:Name="StartWithWindowsCheck" Content="Launch on startup" FontSize="13"
                                  WindowChrome.IsHitTestVisibleInChrome="True"
                                  Checked="StartWithWindowsCheck_Changed" Unchecked="StartWithWindowsCheck_Changed"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Screenshots History -->
            <Grid x:Name="HistoryPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="HistoryEmptyText" Grid.Row="0" Text="No captures yet"
                           FontSize="13" Opacity="0.25" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="10,4,10,4">
                    <StackPanel x:Name="HistoryStack"/>
                </ScrollViewer>

                <Border Grid.Row="1" Padding="14,5,14,8">
                    <Grid>
                        <TextBlock x:Name="HistoryCountText" FontSize="11" Opacity="0.3" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="SelectBtn" Content="Select" FontSize="11" Padding="8,3"
                                    Margin="0,0,3,0" WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="ToggleSelectMode"/>
                            <Button x:Name="DeleteSelectedBtn" Content="Delete" FontSize="11"
                                    Padding="8,3" Visibility="Collapsed"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="DeleteSelectedClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- OCR History -->
            <Grid x:Name="OcrPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="OcrEmptyText" Text="No text captures yet"
                           FontSize="13" Opacity="0.25" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,4,14,14">
                    <StackPanel x:Name="OcrStack"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
