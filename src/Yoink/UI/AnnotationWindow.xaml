<Window x:Class="Yoink.UI.AnnotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink - Edit"
        WindowStartupLocation="CenterScreen"
        ThemeMode="System"
        MinWidth="500" MinHeight="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="8,6" BorderBrush="#20FFFFFF" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ArrowBtn" Content="Arrow" GroupName="Tool"
                             IsChecked="True" Click="ToolChanged"
                             Padding="10,5" Margin="0,0,4,0" Tag="Arrow"/>
                <RadioButton x:Name="TextBtn" Content="Text" GroupName="Tool"
                             Click="ToolChanged"
                             Padding="10,5" Margin="0,0,4,0" Tag="Text"/>
                <RadioButton x:Name="HighlighterBtn" Content="Highlight" GroupName="Tool"
                             Click="ToolChanged"
                             Padding="10,5" Margin="0,0,4,0" Tag="Highlighter"/>
                <RadioButton x:Name="RectBtn" Content="Rectangle" GroupName="Tool"
                             Click="ToolChanged"
                             Padding="10,5" Margin="0,0,4,0" Tag="Rectangle"/>
                <RadioButton x:Name="BlurBtn" Content="Blur" GroupName="Tool"
                             Click="ToolChanged"
                             Padding="10,5" Margin="0,0,16,0" Tag="Blur"/>

                <!-- Color presets -->
                <Border Width="24" Height="24" CornerRadius="4" Background="Red"
                        Margin="0,0,4,0" MouseLeftButtonDown="ColorPicked" Tag="Red" Cursor="Hand"/>
                <Border Width="24" Height="24" CornerRadius="4" Background="#FF8800"
                        Margin="0,0,4,0" MouseLeftButtonDown="ColorPicked" Tag="Orange" Cursor="Hand"/>
                <Border Width="24" Height="24" CornerRadius="4" Background="Yellow"
                        Margin="0,0,4,0" MouseLeftButtonDown="ColorPicked" Tag="Yellow" Cursor="Hand"/>
                <Border Width="24" Height="24" CornerRadius="4" Background="#00CC00"
                        Margin="0,0,4,0" MouseLeftButtonDown="ColorPicked" Tag="Green" Cursor="Hand"/>
                <Border Width="24" Height="24" CornerRadius="4" Background="#0088FF"
                        Margin="0,0,4,0" MouseLeftButtonDown="ColorPicked" Tag="Blue" Cursor="Hand"/>
                <Border Width="24" Height="24" CornerRadius="4" Background="White"
                        Margin="0,0,16,0" MouseLeftButtonDown="ColorPicked" Tag="White" Cursor="Hand"
                        BorderBrush="Gray" BorderThickness="1"/>

                <Separator Margin="0,0,16,0"/>

                <Button Content="Undo" Click="UndoClick" Padding="10,5" Margin="0,0,4,0"/>
                <Button Content="Redo" Click="RedoClick" Padding="10,5" Margin="0,0,16,0"/>

                <Separator Margin="0,0,16,0"/>

                <Button Content="Copy" Click="CopyClick" Padding="10,5" Margin="0,0,4,0" FontWeight="SemiBold"/>
                <Button Content="Save" Click="SaveClick" Padding="10,5"/>
            </StackPanel>
        </Border>

        <!-- Canvas area -->
        <Border Grid.Row="1" Background="#1A1A1A" ClipToBounds="True">
            <Canvas x:Name="DrawCanvas"
                    MouseLeftButtonDown="Canvas_MouseDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseUp"
                    ClipToBounds="True"/>
        </Border>
    </Grid>
</Window>
