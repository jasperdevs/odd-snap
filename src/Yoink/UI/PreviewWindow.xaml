<Window x:Class="Yoink.UI.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Width="280" Height="200"
        MouseLeftButtonDown="OnMouseLeftDown"
        MouseRightButtonDown="OnMouseRightDown"
        MouseMove="OnMouseMoveHandler">

    <Border x:Name="RootBorder" CornerRadius="8" Background="#E6202020"
            BorderBrush="#30FFFFFF" BorderThickness="1"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Screenshot thumbnail -->
            <Border Grid.Row="0" CornerRadius="4" ClipToBounds="True">
                <Image x:Name="ThumbnailImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- Action buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button x:Name="CopyBtn" Content="Copy" Click="CopyClick"
                        FontSize="11" Padding="8,3" Margin="0,0,4,0"
                        Background="#30FFFFFF" Foreground="White" BorderThickness="0"/>
                <Button x:Name="EditBtn" Content="Edit" Click="EditClick"
                        FontSize="11" Padding="8,3" Margin="0,0,4,0"
                        Background="#30FFFFFF" Foreground="White" BorderThickness="0"/>
                <Button x:Name="SaveBtn" Content="Save" Click="SaveClick"
                        FontSize="11" Padding="8,3"
                        Background="#30FFFFFF" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
