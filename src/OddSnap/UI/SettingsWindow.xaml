                                                  ToolTip="Use the same image host for Google Lens redirects."
                                                  Checked="AiRedirectLensUploadSyncCheck_Changed"
                                                  Unchecked="AiRedirectLensUploadSyncCheck_Changed"/>
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE898;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Lens upload service" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Pick the public host used before opening Google Lens." Style="{StaticResource SettingDescription}"/>
