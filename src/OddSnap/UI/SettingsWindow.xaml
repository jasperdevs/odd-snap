                                                  ToolTip="Lock center selection to standard landscape."
                                                  AutomationProperties.Name="4:3 center ratio"
                                                  AutomationProperties.HelpText="Keep center selection in a 4 to 3 landscape ratio."/>
                                    <ComboBoxItem Content="3:2"
                                                  ToolTip="Lock center selection to photo landscape."
                                                  AutomationProperties.Name="3:2 center ratio"
                                                  AutomationProperties.HelpText="Keep center selection in a 3 to 2 landscape ratio."/>
                                    <ComboBoxItem Content="9:16"
                                                  ToolTip="Lock center selection to vertical portrait."
                                                  AutomationProperties.Name="9:16 center ratio"
                                                  AutomationProperties.HelpText="Keep center selection in a 9 to 16 portrait ratio."/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

