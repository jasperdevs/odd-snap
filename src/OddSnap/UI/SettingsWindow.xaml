                                                  ToolTip="Show the capture toolbar along the bottom edge."
                                                  AutomationProperties.Name="Bottom capture dock"
                                                  AutomationProperties.HelpText="Place the capture toolbar at the bottom of the screen."/>
                                    <ComboBoxItem Content="Left"
                                                  ToolTip="Show the capture toolbar along the left edge."
                                                  AutomationProperties.Name="Left capture dock"
                                                  AutomationProperties.HelpText="Place the capture toolbar on the left side of the screen."/>
                                    <ComboBoxItem Content="Right"
                                                  ToolTip="Show the capture toolbar along the right edge."
