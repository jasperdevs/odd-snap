                                    <ComboBoxItem Content="Free"
                                                  ToolTip="Do not lock the center selection ratio."
                                                  AutomationProperties.Name="Free center ratio"
                                                  AutomationProperties.HelpText="Let center selection resize freely without an aspect-ratio lock."/>
