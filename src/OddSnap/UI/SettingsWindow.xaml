                                                  AutomationProperties.Name="Copy after capture"
                                                  AutomationProperties.HelpText="Copy the saved capture to the clipboard and skip the preview window."/>
                                    <ComboBoxItem Content="Preview + Copy"
                                                  ToolTip="Open a preview and copy the capture."
                                                  AutomationProperties.Name="Preview and copy after capture"
                                                  AutomationProperties.HelpText="Open the preview window and also copy the saved capture to the clipboard."/>
                                    <ComboBoxItem Content="Preview only"
                                                  ToolTip="Open a preview without copying."
                                                  AutomationProperties.Name="Preview only after capture"
                                                  AutomationProperties.HelpText="Open the preview window without copying the saved capture to the clipboard."/>
                                </ComboBox>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <Grid Style="{StaticResource SettingRow}">
