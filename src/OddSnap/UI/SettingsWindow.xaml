                                                      ToolTip="Pick the CUDA model used for local upscaling."
                                                      SelectionChanged="UpscaleLocalGpuEngineCombo_Changed">
                                            <ComboBoxItem Content="Real-ESRGAN x4plus (Best quality)" Tag="RealEsrganX4Plus"/>
                                            <ComboBoxItem Content="SwinIR x4 (Faithful / UI)" Tag="SwinIrRealWorld"/>
                                        </ComboBox>
                                    </Grid>
                                    <TextBlock x:Name="UpscaleLocalEngineStatusText" Text="Pick a model. Models download automatically on first use." Style="{StaticResource SettingsStatusText}"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                               AutomationProperties.Name="Upscale local runtime status"
                                               AutomationProperties.LiveSetting="Polite"/>
                                    <ProgressBar x:Name="UpscaleLocalEngineProgress" Height="6" Margin="0,8,0,0" Minimum="0" Maximum="100" Visibility="Collapsed"/>
                                    <TextBlock x:Name="UpscaleLocalEngineProgressText" Style="{StaticResource SettingsProgressText}" Visibility="Collapsed"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                               AutomationProperties.Name="Upscale local runtime progress"
                                               AutomationProperties.LiveSetting="Polite"/>
                                    <WrapPanel Margin="0,10,0,-8">
                                        <Button x:Name="UpscaleInstallDriversBtn" Content="Install runtime" Margin="0,0,8,8"
                                                ToolTip="Install or remove the local upscale runtime"
                                                AutomationProperties.Name="Install upscale runtime"
                                                Click="UpscaleInstallDriversBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="UpscaleDownloadModelBtn" Content="Download model"
                                                Margin="0,0,8,8" ToolTip="Download the selected local upscale model"
                                                AutomationProperties.Name="Download upscale model"
                                                Click="UpscaleDownloadModelBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="UpscaleOpenLocalEngineRepoBtn" Content="Open engine project" Margin="0,0,8,8"
