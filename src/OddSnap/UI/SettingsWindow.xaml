                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource SettingIconFrame}">
                                <TextBlock Text="&#xE9D5;" Style="{StaticResource SettingIconGlyph}"/>
                            </Border>
