                                        AutomationProperties.Name="Export settings"
                                        Cursor="Hand" Click="ExportSettingsButton_Click"/>
                                <Button x:Name="ImportSettingsBtn" Content="Import settings" MinWidth="96"
                                        Margin="0,0,10,8" ToolTip="Import settings from a JSON file"
                                        AutomationProperties.Name="Import settings"
                                        Cursor="Hand" Click="ImportSettingsButton_Click"/>
                            </WrapPanel>
                            <TextBlock x:Name="SettingsImportExportStatusText" Style="{StaticResource SettingsHelperText}"
                                       Visibility="Collapsed"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                       AutomationProperties.Name="Settings import and export status"
                                       AutomationProperties.LiveSetting="Polite"
                                       Margin="0,0,0,10"/>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,4,0,12"/>
                            <WrapPanel Orientation="Horizontal">
                                <Button x:Name="ResetSettingsBtn" Content="Reset Settings" Style="{StaticResource DangerButton}"
                                        ToolTip="Reset all settings to defaults"
                                        AutomationProperties.Name="Reset settings"
                                        Cursor="Hand" Click="ResetSettingsButton_Click" Margin="0,0,10,8"/>
                                <Button x:Name="UninstallOddSnapBtn" Content="Uninstall OddSnap" Style="{StaticResource DangerButton}"
                                        ToolTip="Start the OddSnap uninstall flow"
                                        AutomationProperties.Name="Uninstall OddSnap"
                                        Cursor="Hand" Click="UninstallButton_Click" Margin="0,0,10,8"/>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="VersionText" FontSize="10.5" Opacity="0.28" HorizontalAlignment="Center" Margin="0,18,0,4"/>

                    <TextBlock Text="Links" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,7">
                                <Hyperlink NavigateUri="https://github.com/jasperdevs/odd-snap" RequestNavigate="Hyperlink_Navigate"
                                           Style="{StaticResource AboutActionLink}" FontSize="12">Source Code</Hyperlink>
                                <Run Text=" — GitHub repository" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </TextBlock>
                            <TextBlock Margin="0,0,0,7">
                                <Hyperlink NavigateUri="https://github.com/jasperdevs/odd-snap/releases/latest" RequestNavigate="Hyperlink_Navigate"
                                           Style="{StaticResource AboutActionLink}" FontSize="12">Releases</Hyperlink>
                                <Run Text=" — Download the latest version" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </TextBlock>
                            <TextBlock Margin="0,0,0,7">
                                <Hyperlink NavigateUri="https://github.com/jasperdevs/odd-snap/issues" RequestNavigate="Hyperlink_Navigate"
                                           Style="{StaticResource AboutActionLink}" FontSize="12">Issues</Hyperlink>
                                <Run Text=" — Report bugs or request features" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </TextBlock>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/jasperdevs/odd-snap/blob/main/LICENSE" RequestNavigate="Hyperlink_Navigate"
                                           Style="{StaticResource AboutActionLink}" FontSize="12">License</Hyperlink>
                                <Run Text=" — MIT" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- History (merged: Screenshots + Text sub-tabs) -->
            <Grid x:Name="HistoryPanel" Visibility="Collapsed" Margin="22,42,22,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Category dropdown + actions -->
                <Border Grid.Row="0" Padding="0,0,0,6">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="SelectBtn" Content="Select" Style="{StaticResource HistoryActionButton}"
                                         Margin="0,0,6,0" ToolTip="Select history items"
                                         AutomationProperties.Name="Select history items"
                                         AutomationProperties.HelpText="Select history items"
                                         Cursor="Hand" Click="ToggleSelectMode"/>
                                <Button x:Name="DeleteAllBtn" Content="Clear all" Style="{StaticResource HistoryDangerButton}"
                                        ToolTip="Delete all items in the current history tab"
                                        AutomationProperties.Name="Clear current history tab"
                                        AutomationProperties.HelpText="Delete all items in the current history tab"
                                        Cursor="Hand" Click="DeleteAllClick"/>
                                <Button x:Name="DeleteSelectedBtn" Content="Delete selected" Style="{StaticResource HistoryDangerButton}"
                                         Margin="6,0,0,0" Visibility="Collapsed"
                                         ToolTip="Delete selected history items"
                                         AutomationProperties.Name="Delete selected history items"
                                         AutomationProperties.HelpText="Delete selected history items"
                                         Cursor="Hand" Click="DeleteSelectedClick"/>
                            </StackPanel>
                            <ComboBox x:Name="HistoryCategoryCombo"
                                      MinWidth="130" Margin="0,0,8,0" VerticalAlignment="Center"
                                      ToolTip="Choose the history category"
                                      AutomationProperties.Name="History category"
                                      SelectionChanged="HistoryCategoryCombo_Changed"
                                      PreviewMouseLeftButtonDown="HistoryCategoryCombo_PreviewMouseLeftButtonDown">
                                <ComboBoxItem Content="Images" IsSelected="True"
                                              ToolTip="Show screenshot history"
                                              AutomationProperties.Name="Image history"
                                              AutomationProperties.HelpText="Show saved screenshot captures."/>
                                <ComboBoxItem Content="Text"
                                              ToolTip="Show OCR text history"
                                              AutomationProperties.Name="Text history"
                                              AutomationProperties.HelpText="Show saved OCR text captures."/>
                                <ComboBoxItem Content="Videos/GIFs"
                                              ToolTip="Show video and GIF history"
                                              AutomationProperties.Name="Video and GIF history"
                                              AutomationProperties.HelpText="Show saved video recordings and GIF captures."/>
                                <ComboBoxItem Content="Colors"
                                              ToolTip="Show color history"
                                              AutomationProperties.Name="Color history"
                                              AutomationProperties.HelpText="Show saved color picks."/>
                                <ComboBoxItem Content="Stickers"
                                              ToolTip="Show sticker history"
                                              AutomationProperties.Name="Sticker history"
                                              AutomationProperties.HelpText="Show saved sticker captures."/>
                                <ComboBoxItem Content="Codes"
                                              ToolTip="Show QR and barcode history"
                                              AutomationProperties.Name="Code history"
                                              AutomationProperties.HelpText="Show saved QR and barcode scans."/>
                            </ComboBox>
                            <ComboBox x:Name="HistoryUploadFilterCombo"
                                      MinWidth="128" Margin="0,0,8,0" VerticalAlignment="Center"
                                      ToolTip="Filter history by upload state"
                                      AutomationProperties.Name="Upload state filter"
                                      SelectionChanged="HistoryUploadFilterCombo_Changed">
                                <ComboBoxItem Content="All uploads" Tag="All" IsSelected="True"
                                              ToolTip="Show all upload states"
                                              AutomationProperties.Name="All uploads"
                                              AutomationProperties.HelpText="Show uploaded, not uploaded, and failed history items."/>
                                <ComboBoxItem Content="Uploaded" Tag="Uploaded"
                                              ToolTip="Show uploaded history items"
                                              AutomationProperties.Name="Uploaded history items"
                                              AutomationProperties.HelpText="Show items with a successful upload URL."/>
                                <ComboBoxItem Content="Not uploaded" Tag="NotUploaded"
                                              ToolTip="Show history items that have not uploaded"
                                              AutomationProperties.Name="Not uploaded history items"
                                              AutomationProperties.HelpText="Show items without an upload URL or upload error."/>
                                <ComboBoxItem Content="Failed" Tag="Failed"
                                              ToolTip="Show history items with upload errors"
                                              AutomationProperties.Name="Failed upload history items"
                                              AutomationProperties.HelpText="Show items with an upload error."/>
                            </ComboBox>
                            <ComboBox x:Name="HistoryUploadProviderCombo"
                                      MinWidth="138" Margin="0,0,8,0" VerticalAlignment="Center"
                                      ToolTip="Filter history by upload provider"
                                      AutomationProperties.Name="Upload provider filter"
                                      SelectionChanged="HistoryUploadProviderCombo_Changed"/>
                        </DockPanel>

                        <Grid x:Name="ImageSearchRow" Margin="0,8,0,0" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                            <Border Background="{DynamicResource ThemeInputBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="10,6">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="ImageSearchIcon" Width="14" Height="14" Stretch="Uniform"
                                               VerticalAlignment="Center" Opacity="0.35"/>
                                        <Grid Grid.Column="1" Margin="8,0,0,0">
                                            <TextBox x:Name="ImageSearchBox" BorderThickness="0" Background="Transparent"
                                                     Padding="0" MinHeight="0" Height="20" VerticalContentAlignment="Center"
                                                     ToolTip="Search the current history category"
                                                     AutomationProperties.Name="History search"
                                                     TextChanged="ImageSearchBox_TextChanged"
                                                     PreviewKeyDown="ImageSearchBox_PreviewKeyDown"
                                                     GotKeyboardFocus="ImageSearchBox_FocusChanged"
                                                     LostKeyboardFocus="ImageSearchBox_FocusChanged"/>
                                            <TextBlock x:Name="ImageSearchPlaceholder" Text="Search screenshots, OCR text, or filenames..."
                                                       FontSize="12" Opacity="0.28" VerticalAlignment="Center"
                                                       IsHitTestVisible="False" Margin="0,0,0,0"/>
                                        </Grid>
                                    </Grid>

                                    <TextBlock x:Name="ImageSearchFiltersSummaryText" Visibility="Collapsed"/>
                                    <StackPanel x:Name="ReindexAllProgressPanel" Orientation="Horizontal" Visibility="Collapsed">
                                        <ProgressBar x:Name="ReindexAllProgressBar" Width="60" Height="3" IsIndeterminate="True" Visibility="Collapsed"/>
                                        <Button x:Name="ReindexAllBtn" Content="Index" Style="{StaticResource HistoryActionButton}"
                                                ToolTip="Refresh the image search index"
                                                AutomationProperties.Name="Refresh image search index"
                                                Cursor="Hand" Click="ReindexAllBtn_Click"/>
                                    </StackPanel>
                                    <ProgressBar x:Name="ImageSearchLoadingBar" Width="110" Height="3"
                                                 IsIndeterminate="True" Visibility="Collapsed"
                                                 Margin="22,6,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                            <Button x:Name="ImageSearchFiltersBtn" Grid.Column="1" Content="Filters" Style="{StaticResource HistoryActionButton}"
                                    Margin="8,0,0,0" VerticalAlignment="Stretch"
                                    ToolTip="Choose image search sources and exact matching"
                                    AutomationProperties.Name="Image search filters"
                                    AutomationProperties.HelpText="Open search source and exact-match options for History."
                                    Cursor="Hand" Click="ImageSearchFiltersBtn_Click">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="ImageSearchFiltersMenu" Placement="Bottom"
                                                 AutomationProperties.Name="Image search filter options">
                                        <MenuItem x:Name="ImageSearchFileNameCheck" Header="File name" IsCheckable="True"
                                                  ToolTip="Search screenshot file names"
                                                  AutomationProperties.Name="Search file names"
                                                  AutomationProperties.HelpText="Include screenshot file names in History search results."
                                                  Checked="ImageSearchSourcesCheck_Changed" Unchecked="ImageSearchSourcesCheck_Changed"/>
                                        <MenuItem x:Name="ImageSearchOcrCheck" Header="OCR text" IsCheckable="True"
                                                  ToolTip="Search recognized screenshot text"
                                                  AutomationProperties.Name="Search OCR text"
                                                  AutomationProperties.HelpText="Include recognized text from indexed screenshots in History search results."
                                                  Checked="ImageSearchSourcesCheck_Changed" Unchecked="ImageSearchSourcesCheck_Changed"/>
                                        <Separator/>
                                        <MenuItem x:Name="ImageSearchExactMatchCheck" Header="Exact match" IsCheckable="True"
                                                  ToolTip="Require exact phrase/token matches"
                                                  AutomationProperties.Name="Exact match search"
                                                  AutomationProperties.HelpText="Only show History search results that match the exact phrase or token."
                                                  Checked="ImageSearchExactMatchCheck_Changed" Unchecked="ImageSearchExactMatchCheck_Changed"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Images history -->
                <ScrollViewer x:Name="ImagesPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,2,10,4"
                              ScrollChanged="HistoryPanel_ScrollChanged">
                    <StackPanel x:Name="HistoryStack"/>
                </ScrollViewer>

                <!-- Videos / GIF history -->
                <ScrollViewer x:Name="GifsPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,2,10,4"
                              ScrollChanged="GifPanel_ScrollChanged"
                              Visibility="Collapsed">
                    <StackPanel x:Name="GifStack"/>
                </ScrollViewer>

                <!-- Text history -->
                <ScrollViewer x:Name="TextPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="10,2,10,14" Visibility="Collapsed"
                              ScrollChanged="OcrPanel_ScrollChanged">
                    <StackPanel x:Name="OcrStack"/>
                </ScrollViewer>

                <!-- Color history -->
                <ScrollViewer x:Name="ColorsPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="10,2,10,14" Visibility="Collapsed"
                              ScrollChanged="ColorsPanel_ScrollChanged">
                    <StackPanel x:Name="ColorStack"/>
                </ScrollViewer>

                <!-- Sticker history -->
                <ScrollViewer x:Name="StickersPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="10,2,10,4" Visibility="Collapsed"
                              ScrollChanged="StickerPanel_ScrollChanged">
                    <StackPanel x:Name="StickerStack"/>
                </ScrollViewer>

                <!-- Code/QR history -->
                <ScrollViewer x:Name="CodesPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="10,2,10,14" Visibility="Collapsed"
                              ScrollChanged="CodesPanel_ScrollChanged">
                    <StackPanel x:Name="CodeStack"/>
                </ScrollViewer>

                <!-- Empty states -->
                <StackPanel x:Name="HistoryEmptyText" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed" Margin="0,0,0,40" MaxWidth="300">
                    <TextBlock x:Name="HistoryEmptyTitle" Text="No captures yet" FontSize="14"
                               FontFamily="Segoe UI Variable Text" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Opacity="0.72"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                               AutomationProperties.Name="History empty state title"
                               AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="HistoryEmptyLabel" Text="Screenshots will appear here after capture." FontSize="12.5"
                               FontFamily="Segoe UI Variable Text" Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               Opacity="0.58" HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,7,0,0"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                               AutomationProperties.Name="History empty state detail"
                               AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <Button x:Name="HistoryEmptyRetryButton" Content="Retry" Style="{StaticResource HistoryActionButton}"
                            HorizontalAlignment="Center" Margin="0,14,0,0" Visibility="Collapsed"
                            ToolTip="Retry loading history"
                            AutomationProperties.Name="Retry loading history"
                            AutomationProperties.HelpText="Retry loading history"
                            Cursor="Hand" Click="HistoryEmptyRetryButton_Click"/>
                </StackPanel>

                <!-- Bottom bar -->
                <Border Grid.Row="2" Padding="14,4,14,8">
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="HistoryCountText" FontSize="11" Opacity="0.4" VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.Name="History item count"
                                   AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.LiveSetting="Polite"/>
                        <TextBlock x:Name="HistorySearchStatusText" FontSize="11" Opacity="0.35" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" Margin="12,0,0,0"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.Name="History status"
                                   AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </DockPanel>
                </Border>
            </Grid>

