                                        Click="AiRedirectTestBtn_Click" Cursor="Hand"/>
                                <TextBlock x:Name="AiRedirectTestStatusText" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                           Style="{StaticResource SettingsStatusText}" Visibility="Collapsed"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                           AutomationProperties.Name="AI redirect test status"
                                           AutomationProperties.LiveSetting="Polite"
                                           Margin="0,8,0,0"/>
                            </Grid>
                        </Border>

