            <ScrollViewer x:Name="UploadsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="18,42,18,18">
                <StackPanel>
                    <Border Padding="0,0,0,10">
                        <WrapPanel>
                            <RadioButton x:Name="UploadImagesSubTab" Content="Images" GroupName="UploadSub"
                                         IsChecked="True" Click="UploadSubTabChanged" Style="{StaticResource SubTab}"/>
                            <RadioButton x:Name="UploadAiRedirectsSubTab" Content="AI Redirects" GroupName="UploadSub"
                                         Click="UploadSubTabChanged" Margin="2,0,0,0" Style="{StaticResource SubTab}"/>
                            <RadioButton x:Name="UploadStickersSubTab" Content="Stickers" GroupName="UploadSub"
                                         Click="UploadSubTabChanged" Margin="2,0,0,0" Style="{StaticResource SubTab}"/>
                            <RadioButton x:Name="UploadUpscaleSubTab" Content="Upscale" GroupName="UploadSub"
                                         Click="UploadSubTabChanged" Margin="2,0,0,0" Style="{StaticResource SubTab}"/>
                        </WrapPanel>
                    </Border>

                    <StackPanel x:Name="ImageUploadsPanel">
                        <TextBlock Text="Destination" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Card}">
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE898;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Upload service" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Choose where screenshots and captures are uploaded." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <ComboBox x:Name="UploadDestCombo" Grid.Column="2" MinWidth="145" MaxWidth="240" HorizontalAlignment="Stretch" MaxDropDownHeight="280"
                                          AutomationProperties.Name="Upload service"
                                          ToolTip="Choose where screenshots and captures are uploaded."
                                          SelectionChanged="UploadDestCombo_Changed">
                                    <ComboBoxItem Content="None" Tag="0"/>
                                    <ComboBoxItem Content="Recommended: free/no-setup filter" Tag="21"/>
                                    <ComboBoxItem Content="Litterbox (temp)" Tag="4"/>
                                    <ComboBoxItem Content="tmpfiles.org (temp)" Tag="22"/>
                                    <ComboBoxItem Content="Uguu (temp)" Tag="7"/>
                                    <ComboBoxItem Content="Gofile (free)" Tag="23"/>
                                    <ComboBoxItem Content="Catbox (free)" Tag="3"/>
                                    <ComboBoxItem Content="file.io (temp)" Tag="6"/>
                                    <ComboBoxItem Content="Imgur (API/client ID)" Tag="1"/>
                                    <ComboBoxItem Content="ImgBB (API key)" Tag="2"/>
                                    <ComboBoxItem Content="imgpile (API token)" Tag="24"/>
                                    <ComboBoxItem Content="Gyazo (API token)" Tag="5"/>
                                    <ComboBoxItem Content="Dropbox" Tag="9"/>
                                    <ComboBoxItem Content="Google Drive" Tag="10"/>
