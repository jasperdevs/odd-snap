                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                       AutomationProperties.Name="Auto-upload status"
                                       AutomationProperties.LiveSetting="Polite"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Test upload -->
                    <TextBlock Text="Test" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"
