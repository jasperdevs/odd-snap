                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                               AutomationProperties.Name="Sticker local runtime progress"
                                               AutomationProperties.LiveSetting="Polite"/>
                                    <WrapPanel Margin="0,10,0,-8">
                                        <Button x:Name="StickerInstallDriversBtn" Content="Install runtime" Margin="0,0,8,8"
                                                ToolTip="Install or remove the local sticker runtime"
                                                AutomationProperties.Name="Install sticker runtime"
                                                Click="StickerInstallDriversBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="StickerDownloadRembgBtn" Content="Download model"
