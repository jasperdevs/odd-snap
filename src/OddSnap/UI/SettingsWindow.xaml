                                Content="Reset"
                                MinWidth="82"
                                HorizontalAlignment="Right"
                                AutomationProperties.Name="Reset toolbar layout"
                                ToolTip="Restore the default toolbar layout."
                                Click="ResetToolbarLayoutBtn_Click"/>
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Capture + Saving -->
            <ScrollViewer x:Name="CapturePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,42,18,18">
                <StackPanel>
                    <TextBlock Text="Capture Tool" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE722;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Default capture tool" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Choose which selection mode opens first." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <ComboBox x:Name="DefaultCaptureModeCombo" Grid.Column="2" MinWidth="150"
                                          VerticalAlignment="Center"
                                          AutomationProperties.Name="Default capture tool"
                                          ToolTip="Choose which selection mode opens first."
                                          SelectionChanged="DefaultCaptureModeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Rectangle"
                                                  ToolTip="Drag from corner to corner."
                                                  AutomationProperties.Name="Rectangle selection"
                                                  AutomationProperties.HelpText="Start captures with the standard rectangular selection tool."/>
                                    <ComboBoxItem Content="Center"
                                                  ToolTip="Drag outward from a center point."
                                                  AutomationProperties.Name="Center selection"
                                                  AutomationProperties.HelpText="Start captures with a center-based selection tool."/>
                                    <ComboBoxItem Content="Freeform"
                                                  ToolTip="Draw an irregular capture outline."
                                                  AutomationProperties.Name="Freeform selection"
                                                  AutomationProperties.HelpText="Start captures with the freeform selection tool."/>
                                </ComboBox>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE1D9;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Center aspect ratio" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Optional ratio lock for center selection." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <ComboBox x:Name="CenterAspectRatioCombo" Grid.Column="2" MinWidth="150"
                                          VerticalAlignment="Center"
