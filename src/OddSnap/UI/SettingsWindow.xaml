                                <TextBlock Text="Port" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpPortBox" MinWidth="145" MaxWidth="360" HorizontalAlignment="Stretch" HorizontalScrollBarVisibility="Auto" TextChanged="SftpPortBox_Changed" ToolTip="SFTP port number" AutomationProperties.Name="SFTP port" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
