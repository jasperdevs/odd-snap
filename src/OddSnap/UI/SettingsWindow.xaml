<Window x:Class="OddSnap.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OddSnap.UI.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="OddSnap"
        Height="680" Width="960"
        MinHeight="560" MinWidth="860"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Icon="pack://application:,,,/Assets/oddsnap.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeTabActiveBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="ThemeTabHoverBrush" Color="#0EFFFFFF"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSeparatorBrush" Color="#0CFFFFFF"/>
        <sys:Double x:Key="SettingsControlHeight">30</sys:Double>
        <Thickness x:Key="SettingsControlPadding">10,5</Thickness>
        <sys:Double x:Key="SettingsControlFontSize">12</sys:Double>
        <sys:Double x:Key="SettingsControlMinWidth">88</sys:Double>

        <Style x:Key="TabPill" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{StaticResource OddSnapFocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="12,5" CornerRadius="6" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="11.5"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.55"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTab" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{StaticResource OddSnapFocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="10,4" CornerRadius="5" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="11"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.92"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="Medium"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tb" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Opacity" Value="0.96"/>
            <Setter Property="Margin" Value="0,4,0,6"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{StaticResource OddSnapFocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bd" Padding="9,0" Height="34" CornerRadius="4" Cursor="Hand" Background="Transparent"
                                    Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Icon" Grid.Column="0" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14" Text="&#xE713;" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               Opacity="0.74" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Tb" Grid.Column="1" Text="{TemplateBinding Content}" FontSize="12"
                                               FontFamily="Segoe UI Variable Text"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.82"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="General">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE9E9;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Toast">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE7F4;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Tools">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE90F;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Toolbar">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE7C9;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Capture">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE722;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Recording">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE714;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="OCR">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE8B7;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="History">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE81C;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Uploads">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE898;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="About">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE946;"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.9"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="0.84"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Opacity" Value="0.68"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="Height" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="MinHeight" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="MinWidth" Value="{StaticResource SettingsControlMinWidth}"/>
            <Setter Property="Padding" Value="{StaticResource SettingsControlPadding}"/>
            <Setter Property="FontSize" Value="{StaticResource SettingsControlFontSize}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="Padding" Value="{StaticResource SettingsControlPadding}"/>
            <Setter Property="FontSize" Value="{StaticResource SettingsControlFontSize}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="MaxDropDownHeight" Value="280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid MinWidth="{TemplateBinding MinWidth}"
                              SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleSite"
                                          MinWidth="{TemplateBinding MinWidth}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Border x:Name="Bd"
                                        MinWidth="{TemplateBinding MinWidth}"
                                        MinHeight="{TemplateBinding MinHeight}"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="18"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter x:Name="ContentSite"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                          IsHitTestVisible="False"
                                                          Margin="0,0,6,0"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        <Path Grid.Column="1"
                                              Width="8"
                                              Height="4"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,4,0,0"
                                        Background="{DynamicResource ThemeCardBrush}"
                                        BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer Padding="4"
                                                  CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#35FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="Padding" Value="{StaticResource SettingsControlPadding}"/>
            <Setter Property="FontSize" Value="{StaticResource SettingsControlFontSize}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="Padding" Value="{StaticResource SettingsControlPadding}"/>
            <Setter Property="FontSize" Value="{StaticResource SettingsControlFontSize}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="ToolTip" Value="Hidden for safety. Paste a new value to replace it."/>
            <Setter Property="AutomationProperties.HelpText" Value="Hidden for safety. Paste a new value to replace it."/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track"
                                Width="40"
                                Height="20"
                                CornerRadius="10"
                                Background="#00000000"
                                BorderBrush="{DynamicResource ThemeTextSecondaryBrush}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Ellipse x:Name="Thumb"
                                     Width="12"
                                     Height="12"
                                     Margin="4,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource ThemeTextSecondaryBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="SettingTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SettingDescription" TargetType="TextBlock" BasedOn="{StaticResource InfoText}">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

        <Style x:Key="SettingsHelperText" TargetType="TextBlock" BasedOn="{StaticResource InfoText}">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Opacity" Value="0.56"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SettingsStatusText" TargetType="TextBlock" BasedOn="{StaticResource InfoText}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.58"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="SettingsProgressText" TargetType="TextBlock" BasedOn="{StaticResource InfoText}">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="SettingIconFrame" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SettingIconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Opacity" Value="0.92"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="AboutActionLink" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="TextDecorations" Value="{x:Null}"/>
        </Style>

        <Style x:Key="AboutActionRow" TargetType="Border">
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="AboutIconFrame" TargetType="Border">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InlineTagChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="InlineTagChipDanger" TargetType="Border" BasedOn="{StaticResource InlineTagChip}">
            <Setter Property="Background" Value="#30EF4444"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource OddSnapDangerButton}">
            <Setter Property="Height" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="MinHeight" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Padding" Value="{StaticResource SettingsControlPadding}"/>
            <Setter Property="FontSize" Value="{StaticResource SettingsControlFontSize}"/>
        </Style>

        <Style x:Key="HistoryActionButton" TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="Height" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="MinHeight" Value="{StaticResource SettingsControlHeight}"/>
            <Setter Property="MinWidth" Value="{StaticResource SettingsControlMinWidth}"/>
            <Setter Property="Padding" Value="{StaticResource SettingsControlPadding}"/>
            <Setter Property="FontSize" Value="{StaticResource SettingsControlFontSize}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="HistoryDangerButton" TargetType="Button" BasedOn="{StaticResource DangerButton}">
            <Setter Property="MinWidth" Value="82"/>
        </Style>

        <Style x:Key="HistoryActionsMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="MinWidth" Value="156"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryActionsMenuItem" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="148"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                MinHeight="{TemplateBinding MinHeight}"
                                CornerRadius="4"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProviderIconFrame" TargetType="Border">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ProviderIconImage" TargetType="Image">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style TargetType="{x:Type controls:ProviderSection}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:ProviderSection}">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel x:Name="ProviderHeaderRow" Margin="0,0,0,12" LastChildFill="True">
                                    <ContentControl x:Name="HeaderExtrasHost"
                                                    DockPanel.Dock="Right"
                                                    Content="{TemplateBinding HeaderExtras}"
                                                    VerticalAlignment="Center"/>
                                    <Border x:Name="ProviderHeaderIconFrame" Style="{StaticResource SettingIconFrame}">
                                        <Image x:Name="ProviderHeaderIcon"
                                               Source="{TemplateBinding IconSource}"
                                               Width="16"
                                               Height="16"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               FontFamily="Segoe UI Variable Text"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               Opacity="0.82"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Header" Value="{x:Null}">
                                <Setter TargetName="ProviderHeaderRow" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IconSource" Value="{x:Null}">
                                <Setter TargetName="ProviderHeaderIconFrame" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HeaderExtras" Value="{x:Null}">
                                <Setter TargetName="HeaderExtrasHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

        <Border Margin="1" CornerRadius="12">
    <Border x:Name="OuterBorder" CornerRadius="12" ClipToBounds="True"
            BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
