                                          SelectionChanged="ScrollingCaptureModeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Automatic"
                                                  ToolTip="Let OddSnap collect scrolling frames automatically."
                                                  AutomationProperties.Name="Automatic scrolling capture"
                                                  AutomationProperties.HelpText="Automatically collect frames while scrolling capture is active."/>
                                    <ComboBoxItem Content="Manual"
                                                  ToolTip="Capture scrolling frames only when you click."
