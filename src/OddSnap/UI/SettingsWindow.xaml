                                <ComboBox x:Name="AiRedirectProviderCombo" Grid.Column="2" MinWidth="140" MaxWidth="240" HorizontalAlignment="Stretch" MaxDropDownHeight="240"
                                          AutomationProperties.Name="AI tool"
