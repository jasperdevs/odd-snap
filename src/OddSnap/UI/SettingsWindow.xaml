                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE916;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Capture delay" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Wait before the capture overlay opens." Style="{StaticResource SettingDescription}"/>
