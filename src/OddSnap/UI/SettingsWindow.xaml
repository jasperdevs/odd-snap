                           IsHitTestVisible="False"/>


            <!-- Tools (unified hotkeys + toolbar) -->
            <ScrollViewer x:Name="HotkeysPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="18,42,18,18">
                <StackPanel>
                    <CheckBox x:Name="ShowToolNumberBadgesCheck" Visibility="Collapsed"
                              Checked="ShowToolNumberBadgesCheck_Changed" Unchecked="ShowToolNumberBadgesCheck_Changed"/>
                    <StackPanel x:Name="ToolTogglePanel"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Toolbar layout -->
            <ScrollViewer x:Name="ToolbarPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,42,18,18">
                <StackPanel>
                    <TextBlock Text="Pinned" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}" AllowDrop="True" Drop="ToolbarPinnedList_Drop" DragOver="ToolbarList_DragOver">
                        <StackPanel>
                            <StackPanel x:Name="ToolbarPinnedList"/>
                            <TextBlock x:Name="ToolbarPinnedEmptyText" Text="Drop toolbar items here to pin them." Style="{StaticResource InfoText}" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="More" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>
                    <Border Style="{StaticResource Card}" AllowDrop="True" Drop="ToolbarMoreList_Drop" DragOver="ToolbarList_DragOver">
                        <StackPanel>
                            <StackPanel x:Name="ToolbarMoreList"/>
                            <TextBlock x:Name="ToolbarMoreEmptyText" Text="Unpinned items appear in the toolbar's More menu." Style="{StaticResource InfoText}" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <DockPanel Margin="0,12,0,0">
                        <TextBlock x:Name="ToolbarLayoutStatusText"
                                   DockPanel.Dock="Left"
                                   Style="{StaticResource SettingsStatusText}"
                                   Visibility="Collapsed"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.Name="Toolbar layout status"
                                   AutomationProperties.LiveSetting="Polite"
                                   VerticalAlignment="Center"/>
