                                <TextBlock Text="Username" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="WebDavUsernameBox" MinWidth="145" MaxWidth="360" HorizontalAlignment="Stretch" HorizontalScrollBarVisibility="Auto" TextChanged="WebDavUsernameBox_Changed" ToolTip="Username for WebDAV uploads" AutomationProperties.Name="WebDAV username" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Password" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <PasswordBox x:Name="WebDavPasswordBox" MinWidth="145" MaxWidth="360" HorizontalAlignment="Stretch" PasswordChanged="WebDavPasswordBox_Changed" AutomationProperties.Name="WebDAV password" AutomationProperties.HelpText="Hidden for safety. Paste a new value to replace it." Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Public URL base (optional)" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="WebDavPublicUrlBox" MinWidth="145" MaxWidth="360" HorizontalAlignment="Stretch" HorizontalScrollBarVisibility="Auto" TextChanged="WebDavPublicUrlBox_Changed" ToolTip="Public base URL for WebDAV uploads" AutomationProperties.Name="WebDAV public URL base" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <!-- Custom HTTP settings -->
                    <controls:ProviderSection x:Name="CustomUploadSettings" Header="CUSTOM HTTP" Visibility="Collapsed">
                        <controls:ProviderSection.HeaderExtras>
                            <Border Width="16" Height="16" CornerRadius="3" Background="#5865F2" Margin="0,0,6,0" VerticalAlignment="Center">
                                <TextBlock Text="&#x2B06;" FontSize="9" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            </Border>
                        </controls:ProviderSection.HeaderExtras>
                        <StackPanel>
                            <TextBlock Text="Upload URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
