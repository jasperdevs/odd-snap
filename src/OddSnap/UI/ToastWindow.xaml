<Window x:Class="OddSnap.UI.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="#303030"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        Focusable="False"
        ShowActivated="False">

    <Border x:Name="OuterShell"
            CornerRadius="12"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            SnapsToDevicePixels="True">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="DragScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="SlideTransform" X="0" Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border x:Name="Root" CornerRadius="10" ClipToBounds="True"
                MaxWidth="360" MinWidth="196"
                SnapsToDevicePixels="True">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3"/>
            </Grid.RowDefinitions>

            <Grid x:Name="ContentGrid" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid x:Name="ImageArea" Grid.Row="0" Visibility="Collapsed" MaxHeight="176" HorizontalAlignment="Center">
                    <Border x:Name="ImageFrame" CornerRadius="10,10,0,0" ClipToBounds="True">
                        <Image x:Name="PreviewImage" Stretch="Uniform"
                               UseLayoutRounding="True"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <Border x:Name="CloseBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Close preview"
                            AutomationProperties.Name="Close preview"
                            AutomationProperties.HelpText="Close this preview."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="CloseBtn_KeyDown"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,8,8,0" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="CloseIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="PinBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Pin preview"
                            AutomationProperties.Name="Pin preview"
                            AutomationProperties.HelpText="Keep this preview open."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="PinBtn_KeyDown"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="8,8,0,0" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="PinIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="SaveBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Save preview"
                            AutomationProperties.Name="Save preview"
                            AutomationProperties.HelpText="Save this preview image."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="SaveBtn_KeyDown"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,8,8" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="SaveIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="CopyBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Copy preview"
                            AutomationProperties.Name="Copy preview"
                            AutomationProperties.HelpText="Copy this preview image to the clipboard."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="CopyBtn_KeyDown"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,8,48,0" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="CopyIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="OfficeBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Open with or send to Office"
                            AutomationProperties.Name="Open with or send to Office"
                            AutomationProperties.HelpText="Open this preview with another app or send it to Office."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="OfficeBtn_KeyDown"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="48,8,0,0" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="OfficeIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="AiRedirectBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Open in AI"
                            AutomationProperties.Name="Open in AI"
                            AutomationProperties.HelpText="Open this preview in the configured AI destination."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="AiRedirectBtn_KeyDown"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,48,8" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="AiRedirectIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="DeleteBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Delete file"
                            AutomationProperties.Name="Delete file"
                            AutomationProperties.HelpText="Delete the saved file for this preview."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="DeleteBtn_KeyDown"
                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="8,0,0,8" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="DeleteIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <Grid x:Name="TextContentPanel" Grid.Row="1" Margin="14,11,14,11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ColorSwatch" Grid.Column="0" Width="28" Height="28" CornerRadius="8"
                            Margin="0,0,12,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                    <Border x:Name="InlinePreviewHost" Grid.Column="1" Width="44" Height="44" CornerRadius="8"
                            Margin="0,0,12,0" Visibility="Collapsed" VerticalAlignment="Center"
                            Background="#12FFFFFF" BorderBrush="Transparent" BorderThickness="0">
                        <Image x:Name="InlinePreviewImage" Stretch="Uniform" Margin="4"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText" FontSize="12.75" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable Text" TextWrapping="Wrap"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.Name="Toast title"
                                   AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.LiveSetting="Polite"/>
                        <TextBlock x:Name="BodyText" FontSize="11.5" Opacity="0.72" TextWrapping="Wrap"
                                   FontFamily="Segoe UI Variable Text"
                                   MaxWidth="292" Margin="0,2,0,0"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.Name="Toast message"
                                   AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                    <Border x:Name="TextCloseBtn" Grid.Column="3" Width="22" Height="22" CornerRadius="6"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Close notification"
                            AutomationProperties.Name="Close notification"
                            AutomationProperties.HelpText="Close this notification."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="CloseBtn_KeyDown"
                            VerticalAlignment="Top" Margin="10,-2,-4,0"
                            Visibility="Collapsed">
                        <Image x:Name="TextCloseIcon" Width="11" Height="11" Stretch="Uniform" Opacity="0.78"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" ClipToBounds="True">
                <Border x:Name="ProgressTrack"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"/>
                <Border x:Name="ProgressBar"
                        Background="#8CFFFFFF"
                        HorizontalAlignment="Stretch"
                        RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ProgressScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>

            <Border x:Name="ShellStroke"
                    Grid.RowSpan="2"
                    Margin="0"
                    CornerRadius="10"
                    Background="Transparent"
                    BorderThickness="0"
                    SnapsToDevicePixels="True"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"/>
            </Grid>
        </Border>
    </Border>
</Window>
